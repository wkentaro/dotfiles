  "permissions": {
    "allow": [],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "viewMode": "default",
  "effortLevel": "xhigh",
  "showThinkingSummaries": true,
