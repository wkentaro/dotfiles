{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "allow": [],
    "defaultMode": "auto"
  },
  "skillOverrides": {
    "copywriting": "user-invocable-only",
    "cro": "user-invocable-only",
    "customer-research": "user-invocable-only",
    "illustrate": "user-invocable-only",
    "prototype": "user-invocable-only",
    "remotion-best-practices": "user-invocable-only",
    "to-prd": "user-invocable-only",
    "to-issues": "user-invocable-only",
    "setup-matt-pocock-skills": "user-invocable-only",
    "impeccable": "user-invocable-only",
    "diagnose": "user-invocable-only",
    "improve-codebase-architecture": "user-invocable-only",
    "grill-me": "user-invocable-only",
    "grill-with-docs": "user-invocable-only",
    "triage": "user-invocable-only",
    "tdd": "user-invocable-only",
    "write-a-skill": "user-invocable-only",
    "handoff": "user-invocable-only",
    "skill-cleaner": "user-invocable-only",
    "deep-research": "user-invocable-only",
    "update-config": "user-invocable-only",
    "keybindings-help": "user-invocable-only"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh blocked",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh working",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh release",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh idle",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/wkentaro/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh idle",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh working",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "viewMode": "default",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "showTurnDuration": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "skipWorkflowUsageWarning": true
}
